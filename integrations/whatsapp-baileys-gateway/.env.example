PORT=8788
HOST=0.0.0.0

# Required. Must match Cloudflare Worker secret DISPATCH_BEARER_TOKEN.
DISPATCH_BEARER_TOKEN=replace-with-strong-token

# Optional. If empty, admin endpoints use DISPATCH_BEARER_TOKEN.
GATEWAY_ADMIN_TOKEN=

BAILEYS_SESSION_DIR=./session
BAILEYS_PRINT_QR=true
BAILEYS_RECONNECT_DELAY_MS=5000
LOG_LEVEL=info

# Appends links from Worker payload to the final outgoing text.
WHATSAPP_APPEND_REFERRAL=true
WHATSAPP_APPEND_UNSUBSCRIBE=true
